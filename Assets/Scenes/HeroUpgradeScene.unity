--- !u!114 &2019592096
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2019592094}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "A. Tr\xE1nh l\u1ED7i \"Modified Operation\" (C\u1EF1c k\u1EF3 quan tr\u1ECDng)\nN\u1EBFu
    b\u1EA1n \u0111ang d\xF9ng v\xF2ng l\u1EB7p foreach \u0111\u1EC3 duy\u1EC7t danh
    s\xE1ch stunnedHeroes trong BattleTurnManager, m\xE0 c\xF9ng l\xFAc \u0111\xF3
    m\u1ED9t Hero l\u1EA1i g\u1ECDi h\xE0m Remove \u0111\u1EC3 x\xF3a ch\xEDnh n\xF3
    kh\u1ECFi danh s\xE1ch \u0111\xF3, Game s\u1EBD b\u1ECB Crash (l\u1ED7i InvalidOperationException).\n\nGi\u1EA3i
    ph\xE1p: Lu\xF4n s\u1EED d\u1EE5ng v\xF2ng l\u1EB7p for ng\u01B0\u1EE3c ho\u1EB7c
    t\u1EA1o m\u1ED9t danh s\xE1ch t\u1EA1m th\u1EDDi khi x\u1EED l\xFD c\xE1c List
    m\xE0 c\xF3 kh\u1EA3 n\u0103ng b\u1ECB thay \u0111\u1ED5i gi\u1EEFa ch\u1EEBng.\n\nB.
    Ph\xE2n t\xE1ch tr\xE1ch nhi\u1EC7m (Decoupling)\nM\u1EB7c d\xF9 Hero g\u1ECDi
    tr\u1EF1c ti\u1EBFp Instance l\xE0 nhanh nh\u1EA5t, nh\u01B0ng n\u1EBFu b\u1EA1n
    mu\u1ED1n chuy\xEAn nghi\u1EC7p h\u01A1n, h\xE3y d\xF9ng C# Events.\n\nHero ph\xE1t
    \u0111i s\u1EF1 ki\u1EC7n: OnEffectCleared.\n\nBattleTurnManager \u0111\u0103ng
    k\xFD l\u1EAFng nghe s\u1EF1 ki\u1EC7n \u0111\xF3 t\u1EEB t\u1EA5t c\u1EA3 c\xE1c
    Hero. Khi th\u1EA5y m\u1ED9t Hero gi\u1EA3i hi\u1EC7u \u1EE9ng, Manager t\u1EF1
    \u0111\u1ED9ng c\u1EADp nh\u1EADt List c\u1EE7a m\xECnh. C\xE1ch n\xE0y gi\xFAp
    Hero kh\xF4ng c\u1EA7n bi\u1EBFt BattleTurnManager l\xE0 ai."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2100000, guid: 79459efec17a4d00a321bdcc27bbc385, type: 2}
